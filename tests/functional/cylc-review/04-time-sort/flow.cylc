[scheduler]
    UTC mode = True
    [[events]]
        stall timeout = PT0S
        abort on stall timeout = True
[scheduling]
    initial cycle point = 2000
    final cycle point = 2000
    [[dependencies]]
        P1Y = "foo & bar & baz => qux"
[runtime]
    # init-script sleep to simulate queue duration
    # script sleep to simulate run duration
    [[foo]]
        init-script = sleep 10
        script = sleep 10
    [[bar]]
        init-script = sleep 30
        script = true
    [[baz]]
        init-script = sleep 20
        script = sleep 30
    [[qux]]
        init-script = true
        script = sleep 2
