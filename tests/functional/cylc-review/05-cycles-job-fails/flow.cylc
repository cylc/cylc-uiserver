#!Jinja2
[scheduler]
    UTC mode = True
[scheduling]
    initial cycle point = 2000
    final cycle point = 2000
    [[graph]]
        P1Y = "loser:fail => rehab => done"
[runtime]
    [[done]]
        script = sleep 1
    [[loser]]
        script = false
    [[rehab]]
        script = """
            cylc set "${CYLC_WORKFLOW_ID}//${CYLC_TASK_CYCLE_POINT}/loser" --out=succeeded
            sleep 1
        """
